{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Top 10 LGAs with the Highest Obesity Burden",
    "fontSize": 16,
    "anchor": "middle"
  },
  "width": 600,
  "height": 300,
  "data": {
    "url": "obesity_data.csv"
  },
  "transform": [
    {
      "window": [{"op": "rank", "as": "rank"}],
      "sort": [{"field": "obese_rate", "order": "descending"}]
    },
    {
      "filter": "datum.rank <= 10"
    }
  ],
  "mark": {
    "type": "bar",
    "color": "#e74c3c",
    "cornerRadiusEnd": 4
  },
  "encoding": {
    "x": {
      "field": "obese_rate",
      "type": "quantitative",
      "title": "Obesity Rate (%)"
    },
    "y": {
      "field": "lga_name",
      "type": "nominal",
      "sort": "-x",
      "title": null,
      "axis": {
        "labelLimit": 200,
        "labelFontSize": 12
      }
    },
    "tooltip": [
      {"field": "lga_name", "type": "nominal", "title": "LGA"},
      {"field": "obese_rate", "type": "quantitative", "title": "Obesity Rate (%)"}
    ]
  }
}