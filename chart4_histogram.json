{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Distribution of Socio-Economic Advantage (SEIFA)",
    "fontSize": 16,
    "anchor": "middle"
  },
  "width": 600,
  "height": 300,
  "data": {
    "url": "seifa_data.csv"
  },
  "mark": {
    "type": "bar",
    "color": "#27ae60",
    "stroke": "white",
    "strokeWidth": 1
  },
  "encoding": {
    "x": {
      "field": "Score",
      "bin": {"maxbins": 20},
      "type": "quantitative",
      "title": "SEIFA Advantage Score Range"
    },
    "y": {
      "aggregate": "count",
      "type": "quantitative",
      "title": "Number of LGAs"
    },
    "tooltip": [
      {"field": "Score", "bin": true, "title": "Score Range"},
      {"aggregate": "count", "title": "Number of LGAs in this Range"}
    ]
  }
}